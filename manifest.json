{
    "manifest_version": 3,
    "default_locale": "en",
    "name": "__MSG_extName__",
    "version": "0.1.0",
    "description": "__MSG_extDescription__",
    "permissions": [
        "activeTab",
        "storage",
        "scripting",
        "unlimitedStorage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_title": "__MSG_extName__"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}